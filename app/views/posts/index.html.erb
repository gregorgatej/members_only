<h1>All Posts</h1>

<% if current_user %>
<br>
<h2>Greetings <%= current_user.username %>!</h2>
<%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete } %>
<br>

<% end %>

<% @posts.each do |post| %>

  <ul>
    <li>
      <p><%= post.title %></p>
      <p><%= post.body %></p>
      <p><%= "Author: #{post.user.username}" if current_user %></p>
    </li>
    <br>
  </ul>

<% end %>

<%= link_to "New Post", new_post_path %>